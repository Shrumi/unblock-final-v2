[START]
--wf-tcp-in=80,443,%DiscordPort%
--wf-udp-in=443,%DiscordPortUPD%,%GamePort%
--wf-tcp-out=80,443,%DiscordPort%
--wf-udp-out=443,%DiscordPortUPD%,%GamePort%

%INIT_LUA%
%INIT_BLOB%
--blob=fake_default_udp:0x00000000000000000000000000000000

--template=START_TLS
--lua-desync=circular:fails=1:retrans=2:maxseq=32768:reset
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=1
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=1:badsum
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=1:tcp_md5:badsum
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=620:repeats=6:badsum
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=620:repeats=6:tcp_md5:badsum
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=620:repeats=6:tcp_ack=-66000:tcp_md5:badsum
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:seqovl=620:repeats=6:tcp_ack=-66000:tcp_md5:badsum:ip_autottl=-1,3-20:ip6_autottl=-1,3-20
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=1
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=1:badsum
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=1:tcp_md5:badsum
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=652:repeats=6:tcp_md5
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=652:repeats=6:tcp_md5:badsum
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=652:repeats=6:tcp_ack=-66000:tcp_md5
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=652:repeats=6:tcp_ack=-66000:tcp_md5:badsum
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:seqovl=652:repeats=6:tcp_ack=-66000:tcp_md5:ip_autottl=-1,3-20:ip6_autottl=-1,3-20

--new
--filter-udp=443
--filter-l7=quic
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=quic_initial
--lua-desync=circular:fails=1:udp_out=4:udp_in=1
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-n2
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d10
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d3
--lua-desync=fake:blob=fake_default_udp:repeats=2:payload=all:out_range=-d10
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-d10
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-n4
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-n3

[discord]
--new
--filter-udp=%DiscordPortUPD%
--filter-l7=discord,stun,quic
--lua-desync=circular:fails=1:udp_out=4:udp_in=1
--payload=quic_initial,discord_ip_discovery,stun
--lua-desync=fake:blob=QUIC_VK:repeats=6
--lua-desync=fake:blob=fake_default_udp
--lua-desync=fake:blob=fake_default_udp:repeats=6
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:ip_autottl=2,3-20:ip6_autottl=2,3-20:payload=unknown
--lua-desync=fake:blob=fake_default_udp:repeats=2:out_range=-d10
--lua-desync=fake:blob=fake_default_udp:out_range=-d10
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:out_range=-d3
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:out_range=-n4
--lua-desync=fake:blob=fake_default_udp:out_range=-n3
--lua-desync=send:repeats=2:ip_autottl=0,3-20
--lua-desync=fake:blob=fake_default_udp:ip_autottl=0,3-20:out_range=-d10
--lua-desync=send:repeats=2:ip6_autottl=0,3-20
--lua-desync=fake:blob=fake_default_udp:ip6_autottl=0,3-20:out_range=-d10

[END]
--new
--filter-tcp=80,443,%DiscordPort%
--filter-l7=http,tls
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--import=START_TLS

[amazon]
use_in>>game_mod

[cloudflare]
use_in>>game_mod

[roblox]
use_in>>game_mod

[game_mod]
--new
--filter-tcp=80,443,%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--import=START_TLS

--new
--filter-udp=0,%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--lua-desync=circular:fails=1:udp_out=4:udp_in=1
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-n2
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d10
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-d10
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-n4
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-n3