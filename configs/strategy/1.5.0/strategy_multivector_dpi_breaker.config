--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=6:tcp_md5:badsum
--lua-desync=fake:blob=fake_default_udp:repeats=6:tcp_md5:badsum

--new
--template=START_TLS
--lua-desync=circular:fails=1:retrans=2:maxseq=32768:reset
--lua-desync=syndata:blob=TLS_GOOGLE:nodrop
--lua-desync=fake:blob=TLS_GOOGLE:repeats=6:tcp_ts=-600000
--lua-desync=fake:blob=TLS_GOOGLE:repeats=6:tcp_seq=2
--lua-desync=fake:ip_id=zero:blob=TLS_GOOGLE:repeats=6:tcp_ts=-600000
