--lua-desync=fakedsplit:seqovl_pattern=TLS_GOOGLE:tls_mod=rnd,dupsid,sni=www.google.com:seqovl=726:repeats=8:tcp_seq=1000:nodrop
--lua-desync=hostfakesplit:host=www.google.com:midhost=host-2:seqovl_pattern=fake_default_tcp:seqovl=620:repeats=6:tcp_ts=-600000:nodrop
--lua-desync=hostfakesplit:host=www.google.com:midhost=host-2:seqovl_pattern=fake_default_tcp:seqovl=726:repeats=8:tcp_seq=1000:nodrop
