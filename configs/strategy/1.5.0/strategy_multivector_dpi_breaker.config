--lua-desync=fake:blob=QUIC_SHORT:repeats=8:nodrop
--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=8:nodrop
--lua-desync=fake:blob=NTP4:repeats=8:nodrop
--lua-desync=fake:blob=fake_default_udp:repeats=8:nodrop
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:badsum
--lua-desync=fake:blob=QUIC_VK:repeats=6:badsum
--lua-desync=fake:blob=QUIC_RUTRACKER:repeats=6:badsum
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER1:repeats=6:badsum
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER2:repeats=6:badsum
--lua-desync=fake:blob=QUIC_FACEBOOK:repeats=6:badsum
