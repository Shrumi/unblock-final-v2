--lua-desync=multisplit:pos=1,midsld:seqovl=620:seqovl_pattern=ZERO_512
--lua-desync=multisplit:pos=1,midsld:seqovl=726:seqovl_pattern=ZERO_1024
--lua-desync=fake:blob=fake_default_tls:tls_mod=rnd,dupsid,sni=www.ozon.com
