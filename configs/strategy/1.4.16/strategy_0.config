--new
--filter-udp=443
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--import=START_QUIC

[discord]
--new
--filter-udp=%DiscordPortUPD%
--filter-l7=discord,stun,quic
--payload=quic_initial,discord_ip_discovery,stun
--import=START_QUIC

[END]
--new
--filter-tcp=80,443,%DiscordPort%
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%

[amazon]
use_in>>game_mod

[cloudflare]
use_in>>game_mod

[roblox]
use_in>>game_mod

[game_mod]
--new
--filter-udp=443
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--import=START_QUIC

--new
--filter-tcp=80,443,%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--import=START_TLS

--new
--filter-udp=0,%GamePort%
--payload=all
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--lua-desync=circular:key=udp_rules_game:fails=1:udp_out=4:udp_in=1
--lua-desync=fake:blob=fake_default_udp:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_GOOGLE:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_VK:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_RUTRACKER:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER1:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER2:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_FACEBOOK:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_FACEBOOK_QUICHE:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_SHORT:autottl=2:repeats=12:cutoff=n3
--lua-desync=fake:blob=QUIC_SHORT_HEADER:autottl=2:repeats=12:cutoff=n3