--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=6:tcp_md5:badsum
--lua-desync=fake:blob=fake_default_udp:repeats=6:tcp_md5:badsum

--new
--template=START_TLS
--lua-desync=circular:fails=1:retrans=2:maxseq=32768:reset
--lua-desync=fake:blob=fake_default_tcp:tls_mod=rnd,dupsid,sni=www.google.com:repeats=6:tcp_ts=-600000
--lua-desync=fakedsplit:seqovl_pattern=fake_default_tcp:repeats=6:tcp_ts=-600000:strategy=1
